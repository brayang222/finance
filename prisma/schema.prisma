generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth ──
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  phone         String?       @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  stocks        Stock[]
  crypto        Crypto[]
  finances      Finance[]
  hysAccounts   Hys[]
  hysMovements  HysMovement[]
  prices        Price[]
  targets       Target[]
  cash          Cash?
  config        UserConfig?
  bankAccounts  BankAccount[]
  activityLogs  ActivityLog[]
  budgets       Budget[]
  budgetConfigs BudgetConfig[]
  categories     Category[]
  goals          Goal[]
  recurrings     Recurring[]
  sharesGiven    ShareInvite[] @relation("SharesGiven")
  sharesReceived ShareInvite[] @relation("SharesReceived")
  customers      Customer[]
  fiadoMovements FiadoMovement[]
  products       Product[]
  sales          Sale[]
  cashCloses     CashClose[]

  // Perfil comercio: usuario sombra vinculado al dueño real
  businessOwnerId String?
  businessOwner   User?   @relation("BusinessProfile", fields: [businessOwnerId], references: [id], onDelete: Cascade)
  businessProfiles User[] @relation("BusinessProfile")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ── Finance data ──
model Stock {
  id          String  @id
  userId      String
  date        String
  ticker      String
  qty         Float
  price       Float
  currency    String
  trm         Float
  priceCOP    Float
  commission  Float
  accountId   String?
  accountName String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Crypto {
  id          String  @id
  userId      String
  date        String
  ticker      String
  qty         Float
  price       Float
  currency    String
  trm         Float
  priceCOP    Float
  commission  Float
  accountId   String?
  accountName String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Finance {
  id          String  @id
  userId      String
  date        String
  type        String
  category    String
  desc        String?
  amount      Float
  accountId   String?
  accountName String?
  saleId      String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Hys {
  id        String        @id @default(cuid())
  userId    String
  name      String
  currency  String        @default("COP")
  rate      Float
  openedAt  String?
  movements HysMovement[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model HysMovement {
  id      String  @id
  userId  String
  hysId   String?
  date    String
  type    String
  amount  Float
  balance Float
  note    String?
  rate    Float
  hys     Hys?    @relation(fields: [hysId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Price {
  id     String @id @default(cuid())
  userId String
  ticker String
  value  Float
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}

model Target {
  id     String @id @default(cuid())
  userId String
  ticker String
  value  Float
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}

model Cash {
  id     String  @id @default(cuid())
  userId String  @unique
  banco  Float
  note   String?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserConfig {
  id             String    @id @default(cuid())
  userId         String    @unique
  theme          String    @default("dark")
  onboardingDone Boolean   @default(false)
  showStocks     Boolean   @default(true)
  showCrypto     Boolean   @default(true)
  showHys        Boolean   @default(true)
  showActivity   Boolean   @default(true)
  showGoals      Boolean   @default(true)
  baseCurrency   String    @default("COP")
  trm            Float?
  trmUpdatedAt   DateTime?
  summaryWidgets String?
  telegramId     String?
  salesGoal      Float?    // meta de ventas mensual (perfil comercio)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  name      String
  target    Float
  saved     Float    @default(0)
  deadline  String?
  color     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recurring {
  id          String  @id @default(cuid())
  userId      String
  type        String
  category    String
  desc        String
  amount      Float
  accountId   String?
  accountName String?
  frequency   String
  nextDate    String
  active      Boolean @default(true)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id     String @id @default(cuid())
  userId String
  name   String
  type   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
}

model BankAccount {
  id        String   @id @default(cuid())
  userId    String
  name      String
  bank      String?
  type      String   @default("banco")
  balance   Float    @default(0)
  color     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  description String
  amount      Float?
  ticker      String?
  accountName String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id       String @id @default(cuid())
  userId   String
  category String
  amount   Float
  period   String @default("mensual")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
}

model ShareInvite {
  id         String   @id @default(cuid())
  ownerId    String
  guestEmail String
  guestId    String?
  role       String   @default("viewer")
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  owner      User     @relation("SharesGiven",    fields: [ownerId],  references: [id], onDelete: Cascade)
  guest      User?    @relation("SharesReceived", fields: [guestId],  references: [id], onDelete: SetNull)

  @@unique([ownerId, guestEmail])
}

model BudgetConfig {
  id     String @id @default(cuid())
  userId String
  period String @default("mensual")
  amount Float  @default(0)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

// ── Comercio: clientes y fiado ──
model Customer {
  id        String          @id @default(cuid())
  userId    String
  name      String
  phone     String?
  note      String?
  kind      String          @default("customer") // customer | supplier
  createdAt DateTime        @default(now())
  movements FiadoMovement[]
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FiadoMovement {
  id         String   @id @default(cuid())
  userId     String
  customerId String
  date       String
  type       String   // "fiado" (debe) | "abono" (pago)
  amount     Float
  note       String?
  dueDate    String?  // vencimiento (cuentas por pagar)
  saleId     String?  // venta fiada que originó la deuda
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Comercio: productos, ventas y caja ──
model Product {
  id        String     @id @default(cuid())
  userId    String
  name      String
  category  String?
  cost      Float      @default(0) // costo unitario
  price     Float      // precio de venta
  stock     Float      @default(0)
  minStock  Float      @default(0) // alerta de stock bajo
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  saleItems SaleItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Sale {
  id         String     @id @default(cuid())
  userId     String
  date       String
  total      Float
  cost       Float      @default(0) // costo total de lo vendido (margen)
  payMethod  String     // "cash" | "fiado" | bankAccountId
  customerId String?    // cliente si fue fiado
  note       String?
  createdAt  DateTime   @default(now())
  items      SaleItem[]
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String?
  name      String   // snapshot del nombre
  qty       Float
  price     Float    // snapshot precio unitario
  cost      Float    @default(0)
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model CashClose {
  id           String   @id @default(cuid())
  userId       String
  date         String
  expectedCash Float    // efectivo esperado según la app
  countedCash  Float    // efectivo contado físicamente
  diff         Float    // countedCash - expectedCash
  summary      String?  // JSON: ventas/gastos del día por método
  note         String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
