generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth ──
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  phone         String?       @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  stocks        Stock[]
  crypto        Crypto[]
  finances      Finance[]
  hys           Hys?
  hysMovements  HysMovement[]
  prices        Price[]
  targets       Target[]
  cash          Cash?
  config        UserConfig?
  bankAccounts  BankAccount[]
  activityLogs  ActivityLog[]
  budgets       Budget[]
  budgetConfigs BudgetConfig[]
  categories    Category[]
  goals         Goal[]
  recurrings    Recurring[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ── Finance data ──
model Stock {
  id          String  @id
  userId      String
  date        String
  ticker      String
  qty         Float
  price       Float
  currency    String
  trm         Float
  priceCOP    Float
  commission  Float
  accountId   String?
  accountName String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Crypto {
  id          String  @id
  userId      String
  date        String
  ticker      String
  qty         Float
  price       Float
  currency    String
  trm         Float
  priceCOP    Float
  commission  Float
  accountId   String?
  accountName String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Finance {
  id          String  @id
  userId      String
  date        String
  type        String
  category    String
  desc        String?
  amount      Float
  accountId   String?
  accountName String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Hys {
  id     String @id @default(cuid())
  userId String @unique
  rate   Float
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HysMovement {
  id      String  @id
  userId  String
  date    String
  type    String
  amount  Float
  balance Float
  note    String?
  rate    Float
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Price {
  id     String @id @default(cuid())
  userId String
  ticker String
  value  Float
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}

model Target {
  id     String @id @default(cuid())
  userId String
  ticker String
  value  Float
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}

model Cash {
  id     String  @id @default(cuid())
  userId String  @unique
  banco  Float
  note   String?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserConfig {
  id             String    @id @default(cuid())
  userId         String    @unique
  theme          String    @default("dark")
  onboardingDone Boolean   @default(false)
  showStocks     Boolean   @default(true)
  showCrypto     Boolean   @default(true)
  showHys        Boolean   @default(true)
  showActivity   Boolean   @default(true)
  showGoals      Boolean   @default(true)
  baseCurrency   String    @default("COP")
  trm            Float?
  trmUpdatedAt   DateTime?
  summaryWidgets String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  name      String
  target    Float
  saved     Float    @default(0)
  deadline  String?
  color     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recurring {
  id          String  @id @default(cuid())
  userId      String
  type        String
  category    String
  desc        String
  amount      Float
  accountId   String?
  accountName String?
  frequency   String
  nextDate    String
  active      Boolean @default(true)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id     String @id @default(cuid())
  userId String
  name   String
  type   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
}

model BankAccount {
  id        String   @id @default(cuid())
  userId    String
  name      String
  bank      String?
  type      String   @default("banco")
  balance   Float    @default(0)
  color     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  description String
  amount      Float?
  ticker      String?
  accountName String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id       String @id @default(cuid())
  userId   String
  category String
  amount   Float
  period   String @default("mensual")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
}

model BudgetConfig {
  id     String @id @default(cuid())
  userId String
  period String @default("mensual")
  amount Float  @default(0)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}
